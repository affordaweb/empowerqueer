generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  photoUrl     String?
  role         Role     @default(USER)
  status       Status   @default(PENDING)
  note         String?  @db.VarChar(200)
  lastSeen     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submissions       Submission[]
  activityLogs      ActivityLog[]
  chatMessages      ChatMessage[]
  viewedSubmissions SubmissionView[]
  likes             SubmissionLike[]
  comments          SubmissionComment[]
  createdGroups     ChatGroup[]         @relation("GroupCreator")
  groupMemberships  ChatGroupMember[]
  groupMessages     GroupMessage[]
  adminReplies      VisitorMessage[]    @relation("AdminReplies")
}

model Submission {
  id          String           @id @default(cuid())
  type        SubmissionType
  data        Json
  status      SubmissionStatus @default(PENDING)
  submittedBy String?
  userId      String?
  approvedBy  String?
  publishedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user         User?              @relation(fields: [userId], references: [id])
  views        SubmissionView[]
  activityLogs ActivityLog[]
  likes        SubmissionLike[]
  comments     SubmissionComment[]
}

model SubmissionLike {
  id           String   @id @default(cuid())
  submissionId String
  userId       String
  createdAt    DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@unique([submissionId, userId])
}

model SubmissionComment {
  id           String   @id @default(cuid())
  submissionId String
  userId       String
  content      String   @db.VarChar(500)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])
}

model SubmissionView {
  id           String     @id @default(cuid())
  submissionId String
  userId       String
  viewedAt     DateTime   @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@unique([submissionId, userId])
}

model ActivityLog {
  id           String     @id @default(cuid())
  userId       String
  action       String
  targetType   String?
  targetId     String?
  details      Json?
  createdAt    DateTime   @default(now())

  user       User        @relation(fields: [userId], references: [id])
  submission Submission? @relation(fields: [targetId], references: [id])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  message   String   @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model VisitorConversation {
  id          String   @id @default(cuid())
  sessionId   String   @unique
  visitorName String   @default("Guest")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages VisitorMessage[]
}

model VisitorMessage {
  id             String     @id @default(cuid())
  conversationId String
  senderType     SenderType
  adminId        String?
  message        String     @db.Text
  isRead         Boolean    @default(false)
  createdAt      DateTime   @default(now())

  conversation VisitorConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  admin        User?               @relation("AdminReplies", fields: [adminId], references: [id])
}

model Kopisode {
  id          String   @id @default(cuid())
  title       String
  desc        String   @db.Text
  tags        String[]
  categoryIds String[]
  date        String
  img         String?
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryImage {
  id        String   @id @default(cuid())
  src       String
  alt       String   @default("EmpowerQueer Community Moment")
  tags      String[]
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ChatGroup {
  id        String   @id @default(cuid())
  name      String
  createdBy String
  createdAt DateTime @default(now())

  creator  User              @relation("GroupCreator", fields: [createdBy], references: [id])
  members  ChatGroupMember[]
  messages GroupMessage[]
}

model ChatGroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  joinedAt DateTime @default(now())

  group ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model GroupMessage {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  message   String   @db.Text
  createdAt DateTime @default(now())

  group ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id])
}

enum Role {
  ADMIN
  USER
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

enum SubmissionType {
  EVENT
  TRAINING
  RESOURCE
  OPPORTUNITY
  DIRECTORY
  STORY
  CONTACT
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SenderType {
  VISITOR
  ADMIN
}
